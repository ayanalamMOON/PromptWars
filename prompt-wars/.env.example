# Database
MONGODB_URI=mongodb+srv://promptwars:<password>@prompt-wars-prod.xxxxx.mongodb.net/promptwars?retryWrites=true&w=majority

# Redis
REDIS_URL=rediss://default:<token>@<host>:<port>
UPSTASH_REDIS_REST_URL=https://<host>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# AI APIs
INFERENCE_PROVIDER=ollama           # ollama | groq
OLLAMA_BASE_URL=http://127.0.0.1:11434
GROQ_API_KEY=gsk_...
GOOGLE_AI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Auth
SESSION_SECRET=<random-32-char-string>
ADMIN_PASSWORD=<strong-password>

# App Config
NEXT_PUBLIC_APP_URL=https://promptwars.technous.in
NEXT_PUBLIC_WS_URL=https://prompt-wars-ws.up.railway.app
FROZEN_MODEL=llama-3.3-70b-versatile
JUDGE_MODEL=gemini-2.0-flash
FALLBACK_JUDGE_MODEL=openai/gpt-4o-mini
